# ======================
# 🔑 OpenAI API Settings
# ======================
OPENAI_API_KEY=sk-...
# Модель для GPT‑Vision (опционально переопределите при необходимости)
OPENAI_VISION_MODEL=gpt-5
# Опциональная резервная модель (например, gpt-4o-mini), используется при timeout основной
OPENAI_VISION_MODEL_FALLBACK=gpt-4o-mini
# Таймаут запроса к OpenAI в секундах (по умолчанию 60)
OPENAI_TIMEOUT_SECONDS=60
# Температура выборки (оставьте пустым, чтобы использовать значение по умолчанию модели)
OPENAI_TEMPERATURE=0
# Модель для GPT‑Vision (опционально переопределите при необходимости)
OPENAI_VISION_MODEL=gpt-5
# Температура выборки (оставьте пустым, чтобы использовать значение по умолчанию модели)
OPENAI_TEMPERATURE=0

# ======================
# 🧠 Assistant RAG
# ======================
# Feature flag retrieval-слоя ассистента
ASSISTANT_RAG_ENABLED=0
# Количество чанков, передаваемых в контекст LLM
ASSISTANT_RAG_TOP_K=4
# Минимальный cosine similarity для включения чанка в ответ
ASSISTANT_RAG_MIN_SIMILARITY=0.2
# Количество probes для ivfflat индекса (стабильность ANN-поиска)
ASSISTANT_RAG_IVFFLAT_PROBES=50
# Модель эмбеддингов OpenAI для индексации и retrieval
OPENAI_RAG_EMBEDDING_MODEL=text-embedding-3-small
# Опциональные фильтры retrieval (CSV или JSON-массив)
ASSISTANT_RAG_FILTER_LANG=
ASSISTANT_RAG_FILTER_CATEGORY=
# Ограничение дублей по источнику в выдаче retrieval
ASSISTANT_RAG_MAX_CHUNKS_PER_SOURCE=2

# Прокси для OpenAI/HTTP (если используется)
HTTP_PROXY=http://user:pass@host:port
HTTPS_PROXY=http://user:pass@host:port
# Локальные Docker-сервисы, которые нужно обходить мимо прокси
NO_PROXY=localhost,127.0.0.1,api,bot,db,redis,minio,prometheus,loki,grafana,api.openai.com,securepay.tinkoff.ru,rest-api-test.tinkoff.ru

# ==============================
# 🤖 Telegram Bot Configuration
# ==============================
# Токен Telegram-бота для разработки (BotFather)
BOT_TOKEN_DEV=your-dev-telegram-bot-token-here

# Настройки доступа бота к внутреннему API
API_BASE_URL=http://localhost:8010
API_KEY=test-api-key
API_VER=v1
# Порт HTTP-сервера Prometheus метрик бота
BOT_METRICS_PORT=3000
# Токен для защиты /metrics (если задан, обязателен заголовок X-Metrics-Token)
METRICS_TOKEN=dev-metrics-token
# Таймаут выполнения обработчика Telegraf (мс). 0 или отрицательное значение отключает лимит.
BOT_HANDLER_TIMEOUT_MS=180000
# Количество кнопок в ряду для быстрых чипов растений (1 = вертикально)
OBJECT_CHIPS_ROW_SIZE=1
# Максимум чипов растений в быстрых чипах
OBJECT_CHIPS_LIMIT=6
# ID чата поддержки для /support (может быть отрицательным для супергрупп)
SUPPORT_CHAT_ID=
# Таймаут ожидания сообщения поддержки (мс)
SUPPORT_SESSION_TTL_MS=900000
# QA intake: ID группы для сбора кейсов (можно список через запятую)
QA_INTAKE_CHAT_ID=
# Ограничение доступа к QA intake: CSV список TG ID (пусто = любые участники QA-группы)
QA_INTAKE_TESTER_IDS=
# Таймаут ожидания кейса после команды /qa без аргументов (мс)
QA_INTAKE_SESSION_TTL_MS=1200000
# Максимальный возраст recent_diagnosis для авто-привязки QA кейса (часы)
QA_INTAKE_DIAG_MAX_AGE_H=72
# TG ID администраторов для служебных команд (JSON-массив или CSV)
ADMIN_TG_IDS=[]

# Токен Telegram-бота для продакшена (BotFather)
# BOT_TOKEN_PROD=your-prod-telegram-bot-token-here

# ========================
# 🗄️  Database/PostgreSQL
# ========================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=your_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy строка подключения (используется Alembic)
# Перед запуском миграций укажите эту переменную
DATABASE_URL=sqlite:///./app.db
BOT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agronom
# Redis connection string for rate limiting and queues
REDIS_URL=redis://localhost:6379
# JSON list of trusted proxy IPs for X-Forwarded-For (add Docker gateway or reverse proxy IPs)
TRUSTED_PROXIES=["127.0.0.1","172.18.0.1","testclient"]

